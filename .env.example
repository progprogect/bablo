# Сервер
NODE_ENV=production
PORT=3000

# Railway подставит DATABASE_URL автоматически при подключении PostgreSQL-плагина.
DATABASE_URL=postgres://user:password@localhost:5432/bablo

# 32-байтный hex-ключ для AES-256-GCM шифрования BingX-ключей в БД.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Секрет для подписи сессионной куки (вход по PIN). Любая длинная случайная строка.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
